<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/primaryDark">

    <!-- Full photo -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="3"
        android:background="#000000">

        <ImageView
            android:id="@+id/photoDisplay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:scaleType="fitCenter"/>

        <!-- Index badge -->
        <TextView
            android:id="@+id/photoIndex"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="top|end"
            android:layout_margin="12dp"
            android:background="@drawable/badge_bg"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:paddingTop="4dp"
            android:paddingBottom="4dp"
            android:textColor="@color/white"
            android:textSize="12sp"/>
    </FrameLayout>

    <!-- Info panel -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2"
        android:orientation="vertical"
        android:background="@color/primaryMid"
        android:padding="16dp">

        <!-- Filename -->
        <TextView
            android:id="@+id/photoFilename"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/textSecondary"
            android:textSize="12sp"
            android:ellipsize="middle"
            android:singleLine="true"
            android:paddingBottom="8dp"/>

        <!-- Tags label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="TAGS"
            android:textColor="@color/accent"
            android:textSize="11sp"
            android:letterSpacing="0.2"/>

        <TextView
            android:id="@+id/photoTags"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="14sp"
            android:paddingTop="4dp"
            android:paddingBottom="12dp"
            android:hint="No tags yet"
            android:textColorHint="@color/textSecondary"/>

        <!-- Tag buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingBottom="12dp">

            <Button
                android:id="@+id/btnAddTag"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Add Tag"
                android:textSize="12sp"
                android:layout_marginEnd="8dp"
                app:backgroundTint="@color/accent"/>

            <Button
                android:id="@+id/btnDeleteTag"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_weight="1"
                android:text="Delete Tag"
                android:textColor="@color/accentSoft"
                android:textSize="12sp"
                app:strokeColor="@color/accentSoft"/>
        </LinearLayout>

        <!-- Slideshow controls -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center">

            <Button
                android:id="@+id/btnPrevPhoto"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="◀ Prev"
                android:layout_marginEnd="8dp"
                app:backgroundTint="@color/cardBg"/>

            <Button
                android:id="@+id/btnNextPhoto"
                style="@style/Widget.MaterialComponents.Button"
                android:layout_width="0dp"
                android:layout_height="44dp"
                android:layout_weight="1"
                android:text="Next ▶"
                app:backgroundTint="@color/cardBg"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>